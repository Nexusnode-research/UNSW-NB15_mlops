!notebooks/ids_unsw/models/bundle_xgb/feature_names.json
!notebooks/ids_unsw/models/bundle_xgb/metadata.json

# --- Postman environments (may contain real tokens) ---
*.postman_environment.json
!*.postman_environment.example.json

# --- Jupyter ---
**/.ipynb_checkpoints/
.Trash-0/
**/.Trash-0/

